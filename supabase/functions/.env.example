# Generate a long random value and configure it as an Edge Function secret.
INVITE_RATE_LIMIT_PEPPER=replace-with-a-long-random-secret

# Comma-separated origins allowed to call claim-invite from a browser.
# Include the production site and local development origins when needed.
ALLOWED_ORIGINS=https://example.com,http://127.0.0.1:8000,http://localhost:8000

# RSVP notification emails over SMTP.
ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# false on port 587 uses mandatory STARTTLS; use true only with implicit TLS (usually port 465).
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=replace-with-app-password
SMTP_FROM_EMAIL=Aniversário da Livia - 27 Anos<your-email@gmail.com>
